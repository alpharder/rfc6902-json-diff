{
  "extends": "@tsconfig/node16-strictest/tsconfig.json",
  "include": ["src/**/*"],
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "rootDir": "src",
    "outDir": "dist",
    "noUncheckedIndexedAccess": false,
    "resolveJsonModule": true
  }
}
